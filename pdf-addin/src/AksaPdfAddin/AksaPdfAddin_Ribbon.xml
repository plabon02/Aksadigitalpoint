<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui">
  <ribbon>
    <tabs>
      <tab id="tabPdfAksa" label="AKSA PDF Tools" insertAfterMso="TabHome">

        <!-- ===== FILE ===== -->
        <group id="grpFile" label="File">
          <button id="btnOpenPdf" size="large" label="Open PDF" onAction="OnOpenPdf" getImage="GetImage" screentip="Open PDF" supertip="Open a PDF file in the default PDF viewer (Edge / Adobe Reader)" />
        </group>

        <!-- ===== CONVERT ===== -->
        <group id="grpConvert" label="Convert">
          <button id="btnWordToPdf" size="large" label="Word→PDF" onAction="OnWordToPdf" getImage="GetImage" screentip="Word to PDF" supertip="Save current document as PDF" />
          <button id="btnPdfToWord" size="large" label="PDF→Word" onAction="OnPdfToWord" getImage="GetImage" screentip="PDF to Word" supertip="Open a PDF file and convert it to Word document" />
          <menu id="mnuConvertMore" size="large" label="More" getImage="GetImage" screentip="More Convert Options" supertip="Convert PDF to other formats">
            <button id="btnPdfToExcel" label="PDF → Excel" onAction="OnPdfToExcel" getImage="GetImage" />
            <button id="btnPdfToPpt" label="PDF → PowerPoint" onAction="OnPdfToPpt" getImage="GetImage" />
            <button id="btnPdfToJpg" label="PDF → JPG" onAction="OnPdfToJpg" getImage="GetImage" />
            <menuSeparator />
            <button id="btnBatchWordToPdf" label="Batch Word → PDF" onAction="OnBatchWordToPdf" getImage="GetImage" />
            <button id="btnBatchPdfToWord" label="Batch PDF → Word" onAction="OnBatchPdfToWord" getImage="GetImage" />
          </menu>
        </group>

        <!-- ===== ORGANIZE ===== -->
        <group id="grpOrganize" label="Organize">
          <button id="btnMergePdf" size="large" label="Merge" onAction="OnMergePdf" getImage="GetImage" screentip="Merge PDF" supertip="Combine multiple PDF files into one" />
          <button id="btnSplitPdf" size="large" label="Split" onAction="OnSplitPdf" getImage="GetImage" screentip="Split PDF" supertip="Split a PDF file into separate pages" />
          <menu id="mnuOrganizeMore" size="large" label="More" getImage="GetImage" screentip="More Organize Options" supertip="Reorganize, scan, or remove pages">
            <button id="btnOrganizePages" label="Organize Pages" onAction="OnOrganizePages" getImage="GetImage" />
            <button id="btnRemovePage" label="Remove Page" onAction="OnRemovePage" getImage="GetImage" />
            <button id="btnExtractPages" label="Extract Pages" onAction="OnExtractPages" getImage="GetImage" />
            <menuSeparator />
            <button id="btnScanToPdf" label="Scan → PDF" onAction="OnScanToPdf" getImage="GetImage" />
          </menu>
        </group>

        <!-- ===== OPTIMIZE ===== -->
        <group id="grpOptimize" label="Optimize">
          <button id="btnCompressPdf" size="large" label="Compress" onAction="OnCompressPdf" getImage="GetImage" screentip="Compress PDF" supertip="Reduce PDF file size" />
          <button id="btnOcrPdf" size="large" label="OCR" onAction="OnOcrPdf" getImage="GetImage" screentip="OCR PDF" supertip="Recognize text in scanned PDF using OCR" />
        </group>

        <!-- ===== EDIT ===== -->
        <group id="grpEdit" label="Edit">
          <menu id="mnuEdit" size="large" label="Edit" getImage="GetImage" screentip="Edit PDF" supertip="Edit PDF content, watermark, rotate, crop and more">
            <button id="btnEditPdf" label="Edit Text" onAction="OnEditPdf" getImage="GetImage" />
            <button id="btnWatermark" label="Watermark" onAction="OnWatermark" getImage="GetImage" />
            <button id="btnRotatePdf" label="Rotate Pages" onAction="OnRotatePdf" getImage="GetImage" />
            <button id="btnPageNumber" label="Page Number" onAction="OnPageNumber" getImage="GetImage" />
            <button id="btnCropPdf" label="Crop Pages" onAction="OnCropPdf" getImage="GetImage" />
            <button id="btnPdfForms" label="Forms" onAction="OnPdfForms" getImage="GetImage" />
          </menu>
        </group>

        <!-- ===== SECURITY ===== -->
        <group id="grpSecurity" label="Security">
          <button id="btnProtectPdf" size="large" label="Protect" onAction="OnProtectPdf" getImage="GetImage" screentip="Protect PDF" supertip="Add password protection to a PDF file" />
          <button id="btnUnlockPdf" size="large" label="Unlock" onAction="OnUnlockPdf" getImage="GetImage" screentip="Unlock PDF" supertip="Remove password protection from a PDF" />
          <button id="btnSignPdf" size="large" label="Sign" onAction="OnSignPdf" getImage="GetImage" screentip="Sign PDF" supertip="Add a digital signature or handwritten signature to PDF" />
        </group>

        <!-- ===== INTELLIGENCE ===== -->
        <group id="grpIntelligence" label="Intelligence">
          <button id="btnAiSummarize" size="large" label="Summarize" onAction="OnAiSummarize" getImage="GetImage" screentip="AI Summarize" supertip="Summarize PDF content using AI" />
          <button id="btnTranslate" size="large" label="Translate" onAction="OnTranslate" getImage="GetImage" screentip="Translate PDF" supertip="Translate PDF content to another language using AI" />
        </group>

      </tab>
    </tabs>
  </ribbon>
</customUI>

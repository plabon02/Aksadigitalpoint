      <tab id="tabAksa" label="AKSA 10X FASTER" insertAfterMso="TabHome">
        
        <!-- ============ PAGE GROUP ============ -->
        <group id="grpPage" label="Page Setup">
          <box id="boxPageTop" boxStyle="horizontal">
            <button id="btnAgreementPage" size="normal" label="Agree" onAction="OnAgreementPage" tag="agree_page" getImage="GetImage" screentip="Agreements" supertip="Legal page, SutonnyMJ font for agreements" />
            <button id="btnCvPage" size="normal" label="CV" onAction="OnCvPage" tag="cv_page" getImage="GetImage" screentip="CV" supertip="Set A4 page size, margins, and Arial font for CV" />
          </box>
          <box id="boxPageBottom" boxStyle="horizontal">
            <button id="btnApplicationPage" size="normal" label="App" onAction="OnApplicationPage" tag="app_page" getImage="GetImage" screentip="Application" supertip="Set A4 page size, margins, and Arial font for application" />
            <button id="btnQuestionPage" size="normal" label="Ques" onAction="OnQuestionPage" tag="question_size" getImage="GetImage" screentip="Question" supertip="Set A4 Landscape, 0.5in margins, SutonnyMJ 14pt, 2 columns" />
          </box>
          <menu id="mnuPageNumber" size="large" label="Page No." tag="page_number" getImage="GetImage" screentip="Page Number" supertip="Insert page number at cursor position">
            <button id="btnPageNumBn" label="Bangla Num" tag="page_num_bn" getImage="GetImage" onAction="OnInsertPageNumber" />
            <button id="btnPageNumEn" label="English Num" tag="page_num_en" getImage="GetImage" onAction="OnInsertPageNumber" />
          </menu>
        </group>

        <!-- ============ SAVE GROUP ============ -->
        <group id="grpSave" label="Save As">
          <box id="boxSaveTop" boxStyle="horizontal">
            <button id="btnFolderSelect" size="normal" label="Folder" onAction="OnFolderSelect" tag="save_folder" getImage="GetImage" screentip="Folder Select" supertip="Configure save folders for DOC, PDF, and JPG files" />
            <button id="btnSaveDocFast" size="normal" label="Doc" onAction="OnSaveDoc" tag="save_doc" getImage="GetImage" screentip="Save Doc" supertip="Save document as DOCX in the configured folder" />
          </box>
          <box id="boxSaveBottom" boxStyle="horizontal">
            <button id="btnSavePdfFast" size="normal" label="PDF" onAction="OnSavePdfFast" tag="save_pdf" getImage="GetImage" screentip="Save PDF" supertip="Save document as PDF in the configured folder" />
            <button id="btnSaveJpgFast" size="normal" label="JPG" onAction="OnSaveJpgFast" tag="save_jpg" getImage="GetImage" getEnabled="GetEnabled" screentip="Save JPG" supertip="Save each page as separate JPG image" />
          </box>
          <button id="btnSaveCloseAll" size="large" label="Close" onAction="OnSaveCloseAll" tag="save_close" getImage="GetImage" screentip="Share" supertip="Save all open documents and close them" />

          <menu id="mnuShare" size="large" label="Share" tag="share" getImage="GetImage" screentip="Share" supertip="Share document via Email, WhatsApp, Imo, or Telegram">
            <button id="btnShareEmail" label="Email" tag="share_email" getImage="GetImage" onAction="OnShare" />
            <button id="btnShareWhatsapp" label="WhatsApp" tag="share_whatsapp" getImage="GetImage" onAction="OnShare" />
            <button id="btnShareImo" label="Imo" tag="share_imo" getImage="GetImage" onAction="OnShare" />
            <button id="btnShareTelegram" label="Telegram" tag="share_telegram" getImage="GetImage" onAction="OnShare" />
          </menu>
        </group>

        <!-- ============ SEARCH GROUP ============ -->
        <group id="grpSearch" label="Search">
          <editBox id="txtSearch" label="Search:" sizeString="WWWWWWWWWWWW" onChange="OnSearchChanged" />
        </group>

